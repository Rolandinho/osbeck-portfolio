<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} · {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<header class="site-header">
  <a href="/" class="site-logo">
    <img src="{{ site.logoImage }}" alt="{{ site.title }}">
  </a>
  <nav class="site-nav">
    {% for item in site.nav %}
      <a href="{{ item.href }}"{% if page.url == item.href %} class="active"{% endif %}>{{ item.label }}</a>
    {% endfor %}
    {% if site.social.instagram %}
      <a href="{{ site.social.instagram }}" target="_blank" rel="noopener" class="social-icon">IG</a>
    {% endif %}
    {% if site.social.facebook %}
      <a href="{{ site.social.facebook }}" target="_blank" rel="noopener" class="social-icon">FB</a>
    {% endif %}
  </nav>
</header>

<main>{{ content | safe }}</main>

<footer class="site-footer">
  <span>© 2026 {{ site.title }}</span>
  <div class="social-links">
    {% if site.social.instagram %}
      <a href="{{ site.social.instagram }}" target="_blank" rel="noopener">Instagram</a>
    {% endif %}
    {% if site.social.facebook %}
      <a href="{{ site.social.facebook }}" target="_blank" rel="noopener">Facebook</a>
    {% endif %}
  </div>
  <span>{{ site.url }}</span>
</footer>

<script src="/js/main.js"></script>
</body>
</html>
